":[{"name":"Leibniz-Institut für Kristallzüchtung","address":{"name":"Leibniz-Institut für Kristallzüchtung, Berlin, Germany","@type":"PostalAddress"},"@type":"Organization"}],"@type":"Person"},{"name":"Alice Lassnig","affiliation":[{"name":"Erich Schmid Institute of Materials Science","address":{"name":"Austrian Academy of Sciences, Erich Schmid Institute of Materials Science, Leoben, Austria","@type":"PostalAddress"},"@type":"Organization"}],"@type":"Person"},{"name":"Christoph Gammer","url":"http://orcid.org/0000-0003-1917-4978","affiliation":[{"name":"Erich Schmid Institute of Materials Science","address":{"name":"Austrian Academy of Sciences, Erich Schmid Institute of Materials Science, Leoben, Austria","@type":"PostalAddress"},"@type":"Organization"}],"@type":"Person"},{"name":"Juraj Todt","affiliation":[{"name":"Erich Schmid Institute of Materials Science","address":{"name":"Austrian Academy of Sciences, Erich Schmid Institute of Materials Science, Leoben, Austria","@type":"PostalAddress"},"@type":"Organization"},{"name":"Montanuniversität Leoben","address":{"name":"Chair of Materials Physics, Montanuniversität Leoben, Leoben, Austria","@type":"PostalAddress"},"@type":"Organization"}],"@type":"Person"},{"name":"Jozef Keckes","url":"http://orcid.org/0000-0003-4770-4331","affiliation":[{"name":"Erich Schmid Institute of Materials Science","address":{"name":"Austrian Academy of Sciences, Erich Schmid Institute of Materials Science, Leoben, Austria","@type":"PostalAddress"},"@type":"Organization"},{"name":"Montanuniversität Leoben","address":{"name":"Chair of Materials Physics, Montanuniversität Leoben, Leoben, Austria","@type":"PostalAddress"},"@type":"Organization"}],"@type":"Person"},{"name":"Daniel Rettenwander","url":"http://orcid.org/0000-0002-2074-941X","affiliation":[{"name":"NTNU Norwegian University of Science and Technology","address":{"name":"Department of Material Science and Engineering, NTNU Norwegian University of Science and Technology, Trondheim, Norway","@type":"PostalAddress"},"@type":"Organization"},{"name":"NTNU Norwegian University of Science and Technology","address":{"name":"Christian Doppler Laboratory for Solid-State Batteries, NTNU Norwegian University of Science and Technology, Trondheim, Norway","@type":"PostalAddress"},"@type":"Organization"}],"email":"daniel.rettenwander@ntnu.no","@type":"Person"}],"isAccessibleForFree":true,"@type":"ScholarlyArticle"},"@context":"https://schema.org","@type":"WebPage"}</script>




    
    
    


    
