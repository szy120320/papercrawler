# ============================================================================
# PaperCrawler .gitignore
# ============================================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ---------- 虚拟环境(可重新构建)----------
.venv/
venv/
env/
ENV/

# ---------- IDE / 编辑器 ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- 用户配置(包含 API key / 邮箱,绝不入库) ----------
papercrawler.toml

# ---------- 项目运行产物 ----------
papers/                       # 下载的论文及数据库
*.log
test_*.csv                    # e2e 测试输出
_tmp_*.py                     # 临时脚本
_test_*.py                    # 临时测试
_*.py                         # 本地临时脚本(以下划线开头)

# ---------- OS 垃圾 ----------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ---------- uv 工具链(本地便携二进制,不入库) ----------
uv.exe
uvw.exe
uvx.exe
uv-*.zip

# uv.lock 本身要跟踪(用于依赖复现)
!uv.lock
