# ============================================================================
# PaperCrawler .gitignore
# ============================================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ---------- 虚拟环境(可重新构建)----------
.venv/
venv/
env/
ENV/

# ---------- IDE / 编辑器 ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- 用户配置(包含 API key / 邮箱,绝不入库) ----------
config/papercrawler.toml
papercrawler.toml             # 向后兼容(根目录旧位置)

# ---------- 项目运行产物 ----------
results/                      # 所有 search / download / batch 的输出(每次运行一个子目录)
test_output_*/                # e2e 测试输出目录(根目录的临时测试产物,test_full_flow.py / test_20_papers.py 跑出来)
papers/                       # 老输出位置(2026-06 之前,已迁移到 results/)
*.log
test_*.csv                    # e2e 测试输出
_tmp_*.py                     # 临时脚本
_test_*.py                    # 临时测试
_*.py                         # 本地临时脚本(以下划线开头)

# ---------- OS 垃圾 ----------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ---------- uv 工具链(本地便携二进制,不入库) ----------
uv.exe
uvw.exe
uvx.exe
uv-*.zip

# uv.lock 本身要跟踪(用于依赖复现)
!uv.lock
